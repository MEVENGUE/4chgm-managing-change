# ─────────────────────────────────────────────────────────────
# 4CHGM — Environment variables
# Copy to .env.local for local dev, or set in Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Optional — Railway FastAPI backend (leave empty = mock data in browser)
# After Railway deploy: copy the public URL (no trailing slash)
# NEXT_PUBLIC_API_URL=https://4chgm-api.up.railway.app

# Contact form — Resend (https://resend.com)
# Without RESEND_API_KEY, contact submissions are logged server-side (mock mode)
RESEND_API_KEY=
CONTACT_TO_EMAIL=mevengueengofranck@gmail.com
CONTACT_FROM_EMAIL=4CHGM <onboarding@resend.dev>

# Public app URL (used for metadata / future OAuth callbacks)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
