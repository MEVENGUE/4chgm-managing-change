# 4CHGM — Backend (FastAPI) · Railway / local
# Copy to .env for local dev, or set in Railway → Variables

# CORS — comma-separated frontend origins (no trailing slash)
# Local:  http://localhost:3000
# Vercel: https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:3000

# OpenAI (optional). Without key, /api/ai/chat returns mock answers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Railway sets PORT automatically — do not hardcode in production
# PORT=8000
