# ── 4CHGM Backend — Environment Variables ──

# Core
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# PostgreSQL (Railway auto-injects DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/4chgm

# Redis (Railway Redis plugin)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=generate-a-64-char-random-secret-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
R2_BUCKET_UPLOADS=4chgm-uploads
R2_BUCKET_GENERATED=4chgm-generated
R2_BUCKET_DIAGRAMS=4chgm-diagrams
R2_BUCKET_EXPORTS=4chgm-exports
R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev

# Celery (defaults to REDIS_URL)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Observability
SENTRY_DSN=
