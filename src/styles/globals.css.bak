@import './tokens.css';
@import './theme.css';

@layer base {
  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  html {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }

  body {
    background-color: var(--bg-base);
    color: var(--text-primary);
    transition: background-color var(--duration-slow) var(--ease-default),
                color var(--duration-slow) var(--ease-default);
    min-height: 100vh;
  }
}

@layer components {
  /* Subtle premium glass panels */
  .glass-panel {
    position: relative;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-ring-soft), var(--shadow-sm);
    backdrop-filter: var(--blur-xl) saturate(130%);
    -webkit-backdrop-filter: var(--blur-xl) saturate(130%);
    overflow: hidden;
    isolation: isolate;
    transition: transform
      var(--duration-normal) var(--ease-default),
      box-shadow
      var(--duration-normal) var(--ease-default),
      background var(--duration-normal) var(--ease-default),
      border-color var(--duration-normal) var(--ease-default);
  }

  .glass-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: var(--glass-shine);
    z-index: 1;
    border-radius: inherit;
    mix-blend-mode: overlay;
  }

  .glass-panel:hover {
    transform: translateY(-1px);
    background: var(--bg-surface-hover);
    border-color: var(--border-medium);
    box-shadow: var(--shadow-md), 0 0 0 1px rgba(255,255,255,0.08) inset;
  }

  .glass-panel-strong {
    position: relative;
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.00) 55%), var(--bg-surface-strong);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-3xl);
    box-shadow:
      var(--shadow-ring-soft),
      var(--shadow-lg);
    backdrop-filter: var(--blur-xl) saturate(140%);
    -webkit-backdrop-filter: var(--blur-xl) saturate(140%);
    isolation: isolate;
    overflow: hidden;
    transition: transform
      var(--duration-normal) var(--ease-default),
      box-shadow
      var(--duration-normal) var(--ease-default);
  }

  .glass-panel-strong::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.00) 55%);
    z-index: 0;
    border-radius: inherit;
    mix-blend-mode: overlay;
  }

  .glass-panel-strong > * {
    position: relative;
    z-index: 1;
  }

  .glass-panel-strong:hover {
    transform: translateY(-2px);
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.06) inset,
      var(--shadow-lg);
  }

  .glass-panel-sunken {
    background: linear-gradient(180deg, rgba(0,0,0,0.14) 0%, rgba(0,0,0,0.00) 28%), var(--glass-bg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-2xl);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04), 0 12px 28px rgba(0,0,0,0.24);
    backdrop-filter: var(--blur-xl);
    -webkit-backdrop-filter: var(--blur-xl);
  }

  .sidebar-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border-radius: var(--radius-lg);
    padding: 0.625rem 0.875rem;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    letter-spacing: var(--tracking-wide);
    color: var(--text-secondary);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-default);
    background: transparent;
  }

  .sidebar-item:hover {
    background: var(--sidebar-item-hover);
    color: var(--text-primary);
  }

  .sidebar-item.active {
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.00) 100%), var(--sidebar-item-active);
    color: var(--text-primary);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: var(--shadow-sm);
  }

  .sidebar-item.active::before {
    content: '';
    position: absolute;
    left: -0.2rem;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 60%;
    border-radius: var(--radius-full);
    background: var(--sidebar-indicator);
    box-shadow: 0 0 14px var(--glow-primary);
  }

  .sidebar-item.collapsed {
    justify-content: center;
    padding: 0.625rem;
  }

  .kpi-value {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--text-primary);
  }

  .kpi-label {
    font-size: 0.7rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .kpi-change {
    font-size: 0.7rem;
    font-weight: var(--font-medium);
    color: var(--success);
    letter-spacing: var(--tracking-normal);
  }

  .section-title {
    font-size: 0.7rem;
    font-weight: var(--font-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .topbar-glass {
    position: sticky;
    top: 0;
    z-index: var(--z-topbar);
    background: linear-gradient(180deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.00) 100%), var(--glass-bg);
    border-bottom: 1px solid var(--border-subtle);
    backdrop-filter: var(--blur-xl) saturate(140%);
    -webkit-backdrop-filter: var(--blur-xl) saturate(140%);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), 0 10px 24px rgba(0,0,0,0.18);
  }

  .dropdown-panel {
    background: var(--bg-elevated);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-2xl);
    box-shadow:
      var(--shadow-ring-soft),
      var(--shadow-md),
      0 0 36px -18px var(--glow-primary);
    backdrop-filter: var(--blur-xl);
    -webkit-backdrop-filter: var(--blur-xl);
    overflow: hidden;
  }

  .command-palette {
    background: var(--bg-elevated);
    border: 1px solid var(--border-medium);
    border-radius: var(--radius-3xl);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.08),
      var(--shadow-lg),
      0 0 60px -20px var(--glow-primary);
    backdrop-filter: var(--blur-xl) saturate(145%);
    -webkit-backdrop-filter: var(--blur-xl) saturate(145%);
    overflow: hidden;
  }
}

@layer utilities {

  .dashboard-layout {
    background-color: var(--bg-base);
    min-height: 100vh;
  }
  .dashboard-main { padding: var(--space-6); }
  @media (min-width: 640px) { .dashboard-main { padding: var(--space-6); } }
  @media (min-width: 1024px) { .dashboard-main { padding: var(--space-8); } }

  .flex { display: flex; }
  .flex-col { flex-direction: column; }
  .flex-1 { flex: 1 1 0%; }
  .flex-wrap { flex-wrap: wrap; }
  .items-center { align-items: center; }
  .items-start { align-items: flex-start; }
  .justify-between { justify-content: space-between; }
  .justify-center { justify-content: center; }
  .justify-end { justify-content: flex-end; }
  .hidden { display: none; }
  .w-full { width: 100%; }
  .h-screen { height: 100vh; }
  .min-h-screen { min-height: 100vh; }
  .overflow-hidden { overflow: hidden; }
  .overflow-y-auto { overflow-y: auto; }
  .overflow-x-hidden { overflow-x: hidden; }
  .w-64 { width: var(--sidebar-width); }
  .w-16 { width: var(--sidebar-collapsed); }
  .max-w-2xl { max-width: 42rem; }
  .max-w-lg { max-width: 32rem; }
  .mx-8 { margin-left: 2rem; margin-right: 2rem; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .p-4 { padding: 1rem; }
  .p-5 { padding: 1.25rem; }
  .p-6 { padding: 1.5rem; }
  .p-8 { padding: 2rem; }
  .px-4 { padding-left: 1rem; padding-right: 1rem; }
  .px-3 { padding-left: 0.75rem; padding-right: 0.75rem; }
  .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
  .py-3 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
  .py-2 { padding-top: 0.5rem; padding-bottom: 0.5rem; }
  .py-6 { padding-top: 1.5rem; padding-bottom: 1.5rem; }
  .mt-2 { margin-top: 0.5rem; }
  .mt-3 { margin-top: 0.75rem; }
  .mt-4 { margin-top: 1rem; }
  .mt-5 { margin-top: 1.25rem; }
  .mt-6 { margin-top: 1.5rem; }
  .mb-6 { margin-bottom: 1.5rem; }
  .gap-2 { gap: 0.5rem; }
  .gap-3 { gap: 0.75rem; }
  .gap-4 { gap: 1rem; }
  .gap-5 { gap: 1.25rem; }
  .gap-6 { gap: 1.5rem; }
  .gap-8 { gap: 2rem; }
  .space-y-1 > * + * { margin-top: 0.25rem; }
  .space-y-2 > * + * { margin-top: 0.5rem; }
  .space-y-3 > * + * { margin-top: 0.75rem; }
  .space-y-4 > * + * { margin-top: 1rem; }
  .space-y-6 > * + * { margin-top: 1.5rem; }
  .rounded-xl { border-radius: var(--radius-xl); }
  .rounded-2xl { border-radius: var(--radius-2xl); }
  .rounded-3xl { border-radius: var(--radius-3xl); }
  .rounded-full { border-radius: var(--radius-full); }
  .border { border-width: 1px; border-style: solid; }
  .border-b { border-bottom-width: 1px; border-style: solid; }
  .border-r { border-right-width: 1px; border-style: solid; }
  .text-left { text-align: left; }
  .text-center { text-align: center; }
  .text-right { text-align: right; }
  .text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
  .text-sm { font-size: 0.875rem; line-height: 1.25rem; }
  .text-xs { font-size: 0.75rem; line-height: 1rem; }
  .text-[10px] { font-size: 10px; line-height: 1; }
  .text-[9px] { font-size: 9px; line-height: 1; }
  .font-medium { font-weight: 500; }
  .font-semibold { font-weight: 600; }
  .font-bold { font-weight: 700; }
  .tracking-wide { letter-spacing: 0.025em; }
  .tracking-wider { letter-spacing: 0.05em; }
  .uppercase { text-transform: uppercase; }
  .h-2 { height: 0.5rem; }
  .h-5 { height: 1.25rem; }
  .h-9 { height: 2.25rem; }
  .h-14 { height: 3.5rem; }
  .w-5 { width: 1.25rem; }
  .w-9 { width: 2.25rem; }
  .w-14 { width: 3.5rem; }
  .min-h-[55vh] { min-height: 55vh; }
  .aspect-[3/1] { aspect-ratio: 3/1; }
  .block { display: block; }
  .truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .leading-relaxed { line-height: 1.625; }
  .shrink-0 { flex-shrink: 0; }
  .relative { position: relative; }
  .absolute { position: absolute; }
  .fixed { position: fixed; }
  .inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
  .z-10 { z-index: 10; }
  .z-40 { z-index: 40; }
  .z-50 { z-index: 50; }
  .z-60 { z-index: 60; }
  .opacity-0 { opacity: 0; }
  .opacity-50 { opacity: 0.5; }
  .pointer-events-none { pointer-events: none; }
  .cursor-pointer { cursor: pointer; }
  .outline-none { outline: none; }

  .grid { display: grid; }
  .grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  @media (min-width: 640px) { .sm\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 768px) {
    .md\:flex { display: flex; }
    .md\:hidden { display: none; }
    .md\:block { display: block; }
  }
  @media (min-width: 1024px) {
    .lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .lg\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .lg\:col-span-2 { grid-column: span 2 / span 2; }
    .lg\:col-span-3 { grid-column: span 3 / span 3; }
    .lg\:col-span-5 { grid-column: span 5 / span 5; }
    .lg\:col-span-8 { grid-column: span 8 / span 8; }
    .lg\:col-span-4 { grid-column: span 4 / span 4; }
    .lg\:grid-cols-12 { grid-template-columns: repeat(12, minmax(0, 1fr)); }
    .lg\:hidden { display: none; }
    .lg\:flex { display: flex; }
  }

  .transition { transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
}

@keyframes fade-in-up {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse-soft {
  0%, 100% { opacity: 0.98; }
  50% { opacity: 0.86; }
}

@keyframes glow-pulse {
  0%, 100% { box-shadow: 0 0 22px var(--glow-primary); }
  50% { box-shadow: 0 0 34px var(--glow-primary); }
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-6px); }
}

.animate-fade-in-up { animation: fade-in-up 0.6s ease-out both; }
.animate-pulse-soft { animation: pulse-soft 3.5s ease-in-out infinite; }
.animate-glow-pulse { animation: glow-pulse 3s ease-in-out infinite; }
.animate-float { animation: float 5.5s ease-in-out infinite; }

@keyframes reveal-border {
  from { box-shadow: 0 0 0 rgba(124,92,255,0); }
  to   { box-shadow: 0 0 0 1px rgba(124,92,255,0.14), 0 0 34px -16px rgba(124,92,255,0.32); }
}

.animate-reveal-border {
  animation: reveal-border 0.8s ease-out both;
}
